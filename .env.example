# Supabase project URL and public anon key — found in your Supabase
# project dashboard under Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — server-side only, NEVER expose this to the
# client or commit it. Used for privileged operations (if/when needed).
SUPABASE_SERVICE_ROLE_KEY=

# Base URL of the app (used for OAuth redirects, absolute links, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth Client ID — used by Google One Tap (components/auth/GoogleOneTap.tsx).
# This is the SAME Client ID already configured in Supabase Dashboard >
# Authentication > Providers > Google. It is a public value (safe to expose
# to the client), but the domain you deploy to MUST be added under
# "Authorized JavaScript origins" for this Client ID in Google Cloud
# Console > APIs & Services > Credentials, or One Tap will silently fail.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=844907847047-5enp357k9fa0k3p3sv0f4rkrljsl9s04.apps.googleusercontent.com